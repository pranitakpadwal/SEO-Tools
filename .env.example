# ============================================
# SEO Audit Tool - Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values

# Google PageSpeed Insights API Key
# Get yours at: https://developers.google.com/speed/docs/insights/v5/get-started
# Without this key, the tool uses estimated performance data
GOOGLE_PAGESPEED_API_KEY=your_google_pagespeed_api_key_here

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=SEO Audit Pro

# Request timeout in milliseconds (default: 15000 = 15 seconds)
FETCH_TIMEOUT=15000

# PageSpeed API timeout in milliseconds (default: 30000 = 30 seconds)
PAGESPEED_TIMEOUT=30000
