# ============================================================
# SEO Audit Pro - Environment Variables
# ============================================================
# LOCAL:   Copy this file → .env.local  and fill in values
# RAILWAY: Add these in Railway Dashboard → Service → Variables
# ============================================================

# ── Required for real Core Web Vitals data ──────────────────
# Without this key, estimated performance data is shown.
# Get yours (free): https://developers.google.com/speed/docs/insights/v5/get-started
GOOGLE_PAGESPEED_API_KEY=your_google_pagespeed_api_key_here

# ── App URL ──────────────────────────────────────────────────
# LOCAL:   http://localhost:3000
# RAILWAY: https://your-app.up.railway.app  (set after first deploy)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# App display name
NEXT_PUBLIC_APP_NAME=SEO Audit Pro

# ── Timeouts (milliseconds) ──────────────────────────────────
# How long to wait when fetching a target website
FETCH_TIMEOUT=15000

# How long to wait for the PageSpeed Insights API
PAGESPEED_TIMEOUT=30000

# ── Railway auto-injects these – do NOT set them manually ────
# PORT                    (Railway picks the port automatically)
# RAILWAY_PUBLIC_DOMAIN   (your-app.up.railway.app)
